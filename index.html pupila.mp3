<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Para Você ❤️</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
    }

    body {
      background: linear-gradient(180deg, #0b0014, #14001f);
      color: #fff;
      height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .container {
      z-index: 2;
      max-width: 600px;
      padding: 20px;
    }

    h1 {
      font-size: 2.5em;
      color: #ff6ec7;
      margin-bottom: 15px;
    }

    p {
      font-size: 1.2em;
      line-height: 1.6;
      opacity: 0.9;
    }

    button {
      margin-top: 25px;
      padding: 15px 30px;
      font-size: 1em;
      border: none;
      border-radius: 30px;
      background: #ff6ec7;
      color: #000;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #ff92da;
      transform: scale(1.05);
    }

    /* Corações */
    .heart {
      position: absolute;
      bottom: -20px;
      color: #ff6ec7;
      font-size: 20px;
      animation: floatUp linear forwards;
      opacity: 0.8;
    }

    @keyframes floatUp {
      from {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
      to {
        transform: translateY(-110vh) scale(1.5);
        opacity: 0;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Para o amor da minha vida ❤️</h1>
    <p>
      Cada batida do meu coração lembra você.<br>
      Esse cantinho é só nosso, feito com carinho,<br>
      porque amar você é a coisa mais linda que existe.
    </p>

    <button id="musicBtn">▶ Tocar música</button>
  </div>

  <audio id="music" src="pupila.mp3"></audio>

  <script>
    const music = document.getElementById("music");
    const btn = document.getElementById("musicBtn");
    let playing = false;

    btn.addEventListener("click", () => {
      if (!playing) {
        music.play();
        btn.textContent = "⏸ Pausar música";
      } else {
        music.pause();
        btn.textContent = "▶ Tocar música";
      }
      playing = !playing;
    });

    // Criar corações
    function createHeart() {
      const heart = document.createElement("div");
      heart.classList.add("heart");
      heart.innerHTML = "❤️";
      heart.style.left = Math.random() * 100 + "vw";
      heart.style.fontSize = Math.random() * 20 + 15 + "px";
      heart.style.animationDuration = Math.random() * 3 + 4 + "s";

      document.body.appendChild(heart);

      setTimeout(() => {
        heart.remove();
      }, 7000);
    }

    setInterval(createHeart, 300);
  </script>

</body>
  </html>
